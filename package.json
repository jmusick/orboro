{
  "name": "orboro",
  "type": "module",
  "version": "1.6.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "npm run build && wrangler pages dev dist --ip 127.0.0.1 --port 8787",
    "dev:astro": "astro dev --host 127.0.0.1",
    "build": "astro build && node fix-wrangler.js",
    "preview": "astro preview",
    "astro": "astro",
    "cf:types": "wrangler types",
    "d1:migrate:local": "wrangler d1 migrations apply DB --local",
    "d1:migrate:remote": "wrangler d1 migrations apply DB --remote"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.7",
    "astro": "^6.1.3",
    "marked": "^17.0.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260405.1",
    "wrangler": "^4.80.0"
  }
}
