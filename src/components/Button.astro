---
import Icon from './Icon.astro';

interface Props {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  variant?: 'primary' | 'secondary' | 'tertiary' | 'danger';
  size?: 'sm' | 'md' | 'lg';
  icon?: string;
  iconPosition?: 'left' | 'right';
  class?: string;
  [key: string]: any;
}

const { 
  href, 
  type = 'button', 
  variant = 'primary', 
  size = 'md', 
  icon,
  iconPosition = 'left',
  class: className = '',
  ...rest 
} = Astro.props;

const Element = href ? 'a' : 'button';
const elementProps = href ? { href } : { type };
---

<Element 
  class={`btn btn--${variant} btn--${size} ${className}`}
  {...elementProps}
  {...rest}
>
  {icon && iconPosition === 'left' && (
    <span class="btn__icon">
      <Icon name={icon} size={size === 'sm' ? 16 : size === 'lg' ? 20 : 18} />
    </span>
  )}
  <slot />
  {icon && iconPosition === 'right' && (
    <span class="btn__icon">
      <Icon name={icon} size={size === 'sm' ? 16 : size === 'lg' ? 20 : 18} />
    </span>
  )}
</Element>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border: none;
    border-radius: 8px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
    white-space: nowrap;
    font-family: inherit;
    font-size: inherit;
  }

  .btn--sm {
    padding: 0.4rem 0.8rem;
    font-size: 0.875rem;
  }

  .btn--md {
    padding: 0.6rem 1rem;
    font-size: 1rem;
  }

  .btn--lg {
    padding: 0.8rem 1.4rem;
    font-size: 1.1rem;
  }

  /* Primary Button */
  .btn--primary {
    background: linear-gradient(135deg, var(--accent) 0%, #00b8d4 100%);
    color: #000;
    box-shadow: 0 0 1rem rgb(0 229 255 / 30%);
  }

  .btn--primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 0.5rem 1.5rem rgb(0 229 255 / 40%);
  }

  .btn--primary:active {
    transform: translateY(0);
  }

  /* Secondary Button */
  .btn--secondary {
    background: var(--surface-2);
    color: var(--accent);
    border: 1px solid var(--accent);
  }

  .btn--secondary:hover {
    background: rgb(0 229 255 / 10%);
    box-shadow: 0 0 0.8rem rgb(0 229 255 / 25%);
  }

  /* Tertiary Button */
  .btn--tertiary {
    background: transparent;
    color: var(--accent);
    border: 1px solid transparent;
  }

  .btn--tertiary:hover {
    border-color: var(--accent);
  }

  /* Danger Button */
  .btn--danger {
    background: linear-gradient(135deg, #ff3d4d 0%, #dd2d3a 100%);
    color: white;
  }

  .btn--danger:hover {
    transform: translateY(-2px);
    box-shadow: 0 0.5rem 1.5rem rgb(255 61 77 / 40%);
  }

  .btn__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  /* Focus state */
  .btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>
