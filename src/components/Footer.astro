---
const year = new Date().getFullYear();
const version = "1.1.0";
---

<footer class="site-footer">
  <div class="footer-inner">
    <span class="copyright">&copy; {year} Orboro.net. All rights reserved.</span>
    <span class="version">v{version}</span>
    <nav class="footer-nav">
      <a href="/admin">Admin</a>
      <a href="/privacy-policy">Privacy Policy</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    color: var(--muted);
    font-size: 0.85rem;
    margin-top: 2rem;
    padding-bottom: 2rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
  }

  .copyright {
    justify-self: start;
  }

  .footer-nav {
    display: flex;
    gap: 1.25rem;
    justify-self: end;
  }

  .footer-nav a {
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-nav a:hover {
    color: var(--accent);
  }

  .version {
    justify-self: center;
    opacity: 0.5;
    font-size: 0.8rem;
  }

  @media (max-width: 600px) {
    .footer-inner {
      grid-template-columns: 1fr;
      align-items: center;
      text-align: center;
    }

    .copyright,
    .version,
    .footer-nav {
      justify-self: center;
    }
  }
</style>
