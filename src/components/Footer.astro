---
const year = new Date().getFullYear();
const version = "1.0.0";
---

<footer class="site-footer">
  <div class="footer-inner">
    <span class="copyright">&copy; {year} Orboro.net. All rights reserved. <span class="version">v{version}</span></span>
    <nav class="footer-nav">
      <a href="/privacy-policy">Privacy Policy</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    color: var(--muted);
    font-size: 0.85rem;
    margin-top: 2rem;
    padding-bottom: 2rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-nav {
    display: flex;
    gap: 1.25rem;
  }

  .footer-nav a {
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-nav a:hover {
    color: var(--accent);
  }

  .version {
    opacity: 0.5;
    font-size: 0.8em;
    margin-left: 0.4em;
  }

  @media (max-width: 600px) {
    .footer-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>
