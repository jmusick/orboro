---
interface Props {
  title: string;
  excerpt?: string | null;
  html: string;
}

const { title, excerpt, html } = Astro.props;
---

<article>
  <section class="landing-hero">
    <h1>{title}</h1>
    {excerpt ? <p>{excerpt}</p> : null}
  </section>

  <section class="landing-body" set:html={html} />
</article>

<style>
  .landing-hero {
    padding: 1.5rem;
    border-radius: 14px;
    border: 1px solid #27477d;
    background:
      radial-gradient(circle at 90% 10%, rgb(255 63 184 / 25%) 0%, transparent 33%),
      radial-gradient(circle at 10% 5%, rgb(0 229 255 / 23%) 0%, transparent 38%),
      #121a30;
    box-shadow: 0 0 1.5rem rgb(255 63 184 / 17%);
    margin-bottom: 1.2rem;
  }

  .landing-hero h1 {
    color: #f4f8ff;
    margin-top: 0;
  }

  .landing-hero p {
    max-width: 62ch;
    font-size: 1.06rem;
    color: #d2def2;
  }

  .landing-body {
    line-height: 1.7;
  }

  .landing-body :global(a) {
    color: #00e5ff;
  }

  .landing-body :global(code) {
    background: #111a30;
    border: 1px solid #1f2b46;
    border-radius: 0.35rem;
    padding: 0.1rem 0.35rem;
  }
</style>
