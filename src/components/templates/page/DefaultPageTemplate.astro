---
interface Props {
  title: string;
  excerpt?: string | null;
  html: string;
}

const { title, excerpt, html } = Astro.props;
---

<article>
  <h1>{title}</h1>
  {excerpt ? <p class="excerpt">{excerpt}</p> : null}
  <div class="prose" set:html={html} />
</article>

<style>
  .excerpt {
    color: #a8b8d4;
    font-size: 1.05rem;
    max-width: 64ch;
  }

  .prose {
    line-height: 1.7;
  }

  .prose :global(a) {
    color: #00e5ff;
  }

  .prose :global(hr) {
    border: 0;
    border-top: 1px solid #1f2b46;
  }

  .prose :global(code) {
    background: #111a30;
    border: 1px solid #1f2b46;
    border-radius: 0.35rem;
    padding: 0.1rem 0.35rem;
  }
</style>
