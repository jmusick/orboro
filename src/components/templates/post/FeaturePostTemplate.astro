---
interface Props {
  title: string;
  excerpt?: string | null;
  html: string;
}

const { title, excerpt, html } = Astro.props;
---

<article>
  <header class="feature-hero">
    <p class="kicker">Feature Story</p>
    <h1>{title}</h1>
    {excerpt ? <p class="lede">{excerpt}</p> : null}
  </header>

  <section class="feature-body prose" set:html={html} />
</article>

<style>
  .feature-hero {
    padding: 1.4rem;
    border: 1px solid #27477d;
    border-radius: 14px;
    background:
      radial-gradient(circle at 18% 18%, rgb(0 229 255 / 26%) 0%, transparent 42%),
      radial-gradient(circle at 82% 12%, rgb(255 63 184 / 24%) 0%, transparent 35%),
      #121a30;
    box-shadow: 0 0 1.4rem rgb(0 229 255 / 20%);
    margin-bottom: 1.2rem;
  }

  .kicker {
    text-transform: uppercase;
    letter-spacing: 0.13em;
    font-size: 0.72rem;
    margin: 0;
    color: #85ffe8;
  }

  .lede {
    font-size: 1.08rem;
    max-width: 60ch;
    color: #d2def2;
  }

  .prose {
    line-height: 1.7;
  }

  .prose :global(a) {
    color: #00e5ff;
  }

  .prose :global(h2),
  .prose :global(h3) {
    color: #f4f8ff;
  }

  .prose :global(code) {
    background: #111a30;
    border: 1px solid #1f2b46;
    border-radius: 0.35rem;
    padding: 0.1rem 0.35rem;
  }
</style>
