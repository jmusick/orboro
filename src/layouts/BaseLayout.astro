---
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
import { listNavItems } from "../lib/content";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "" } = Astro.props;
const navItems = await listNavItems(Astro.locals);
const pathname = new URL(Astro.request.url).pathname;

// Build nav tree (unlimited depth)
type NavNode = (typeof navItems)[0] & { children: NavNode[] };

function buildNavTree(items: typeof navItems, parentId: string | null = null): NavNode[] {
  return items
    .filter(i => (i.parentItemId ?? null) === parentId)
    .sort((a, b) => a.sortOrder - b.sortOrder)
    .map(i => ({ ...i, children: buildNavTree(items, i.id) }));
}

function esc(s: string) {
  return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function renderDropdownItems(nodes: NavNode[]): string {
  return nodes.map(node => {
    const active = isActive(node.url) ? ' active' : '';
    if (node.children.length > 0) {
      return `<div class="nav-flyout-item">` +
        `<a href="${esc(node.url)}" class="nav-dropdown-link${active}">${esc(node.label)} <span class="nav-flyout-arrow" aria-hidden="true">›</span></a>` +
        `<div class="nav-flyout">${renderDropdownItems(node.children)}</div>` +
        `</div>`;
    }
    return `<a href="${esc(node.url)}" class="nav-dropdown-link${active}">${esc(node.label)}</a>`;
  }).join('');
}

const navTree = buildNavTree(navItems);

function isActive(url: string): boolean {
  if (url === "/") return pathname === "/";
  return pathname === url || pathname.startsWith(url + "/");
}

function nodeIcon(node: NavNode): string {
  if (node.url.includes("about")) return "user";
  if (node.children.length > 0) return "compass";
  return "file-text";
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <ClientRouter />
    <style is:global>
      :root {
        --bg: #05070f;
        --surface: #0c1324;
        --surface-2: #111a30;
        --text: #e8f3ff;
        --muted: #97a8c4;
        --accent: #00e5ff;
        --accent-2: #ff3fb8;
        --accent-3: #a8ff60;
        --line: #1f2b46;
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        font-family: "Space Grotesk", "Segoe UI", sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at 15% 10%, rgb(0 229 255 / 14%) 0%, transparent 32%),
          radial-gradient(circle at 85% 15%, rgb(255 63 184 / 12%) 0%, transparent 28%),
          radial-gradient(circle at 50% 95%, rgb(168 255 96 / 10%) 0%, transparent 38%),
          var(--bg);
        background-repeat: no-repeat;
        background-size: 140vw 140vh, 130vw 130vh, 150vw 150vh, auto;
        background-attachment: fixed;
      }
      a {
        color: var(--accent);
        text-underline-offset: 2px;
      }
      .container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 1.2rem;
      }
      header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
        padding: 1.5rem 0 1rem;
      }
      .header-logo {
        display: block;
        flex-shrink: 0;
        text-decoration: none;
        line-height: 0;
      }
      .header-logo img {
        width: 240px;
        height: auto;
      }
      nav {
        display: flex;
        align-items: stretch;
        gap: 0;
        margin-bottom: 1rem;
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 10px;
        padding: 0.25rem;
        flex-wrap: wrap;
      }
      nav a {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        border-radius: 7px;
        padding: 0.55rem 1.35rem;
        text-decoration: none;
        transition: all 0.18s ease;
        font-weight: 500;
        font-size: 0.95rem;
        color: var(--muted);
        white-space: nowrap;
      }
      nav a:hover {
        color: var(--text);
        background: rgb(255 255 255 / 5%);
      }
      nav a.active {
        color: var(--accent);
        background: rgb(0 229 255 / 10%);
        box-shadow: inset 0 0 0 1px rgb(0 229 255 / 20%);
      }
      .nav-dropdown-wrapper {
        position: relative;
        display: flex;
        align-items: stretch;
      }
      .nav-dropdown-wrapper > a::after {
        content: "";
        display: inline-block;
        width: 0;
        height: 0;
        border-left: 4px solid transparent;
        border-right: 4px solid transparent;
        border-top: 4px solid currentColor;
        margin-left: 0.45rem;
        opacity: 0.55;
        vertical-align: middle;
        transition: transform 0.18s ease, opacity 0.18s ease;
      }
      .nav-dropdown-wrapper:hover > a::after {
        transform: rotate(180deg);
        opacity: 1;
      }
      .nav-dropdown {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        flex-direction: column;
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 10px;
        padding: 0.25rem;
        min-width: 180px;
        z-index: 50;
        box-shadow: 0 8px 24px rgb(0 0 0 / 45%);
      }
      .nav-dropdown-wrapper:hover .nav-dropdown {
        display: flex;
      }
      .nav-dropdown a, .nav-dropdown-link {
        padding: 0.5rem 1rem;
        font-size: 0.9rem;
        border-radius: 7px;
        box-shadow: none;
        display: block;
        text-decoration: none;
        color: var(--text);
        white-space: nowrap;
        transition: background 0.15s ease, color 0.15s ease;
      }
      .nav-dropdown a:hover, .nav-dropdown-link:hover {
        background: rgb(0 229 255 / 10%);
        color: var(--accent);
      }
      .nav-dropdown a.active, .nav-dropdown-link.active {
        color: var(--accent);
        background: rgb(0 229 255 / 10%);
      }
      .nav-flyout-item {
        position: relative;
      }
      .nav-flyout-item > .nav-dropdown-link {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
      }
      .nav-flyout-arrow {
        display: inline-block;
        font-style: normal;
        opacity: 0.6;
        font-size: 1rem;
        line-height: 1;
        transform: rotate(180deg);
      }
      .nav-flyout {
        display: none;
        position: absolute;
        top: 0;
        left: auto;
        right: 100%;
        flex-direction: column;
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 10px;
        padding: 0.25rem;
        min-width: 180px;
        z-index: 51;
        box-shadow: 0 8px 24px rgb(0 0 0 / 45%);
      }
      .nav-flyout-item:hover > .nav-flyout {
        display: flex;
      }
      .header-banner {
        margin-bottom: 1.2rem;
        border-radius: 16px;
        overflow: hidden;
        line-height: 0;
      }
      .header-banner img {
        display: block;
        width: 100%;
        height: auto;
        max-height: none;
        object-fit: contain;
        border-radius: inherit;
      }
      main {
        background: linear-gradient(160deg, rgb(12 19 36 / 94%) 0%, rgb(17 26 48 / 94%) 100%);
        border: 1px solid var(--line);
        border-radius: 16px;
        box-shadow:
          0 0 1.2rem rgb(0 229 255 / 14%),
          0 1.5rem 3rem rgb(0 0 0 / 45%);
        padding: 2rem;
      }
      section + section {
        margin-top: 2.5rem;
      }
      section {
        animation: fadeIn 0.4s ease-out;
      }
      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      footer {
        /* styles moved to Footer.astro */
      }
      ul {
        padding-left: 1.2rem;
      }
      ul li {
        margin-bottom: 0.5rem;
      }
      input,
      textarea,
      select,
      button {
        font: inherit;
      }
      .mono {
        font-family: "JetBrains Mono", Consolas, monospace;
      }
      h1 {
        font-size: 2.2rem;
        margin: 0 0 1rem;
        font-weight: 700;
      }
      h2 {
        font-size: 1.6rem;
        margin: 0 0 1rem;
        font-weight: 600;
      }
      h3 {
        font-size: 1.2rem;
        margin: 0 0 0.75rem;
        font-weight: 600;
      }
      h1, h2, h3 {
        color: #f4f8ff;
      }
      p {
        line-height: 1.6;
        margin: 0 0 1rem;
      }
      hr {
        border: 0;
        border-top: 1px solid var(--line);
        margin: 2rem 0;
      }
      @media (max-width: 768px) {
        main {
          padding: 1.5rem;
        }
        header {
          flex-direction: column;
          align-items: flex-start;
          gap: 0.75rem;
        }
        nav {
          width: 100%;
        }
        .header-banner {
          margin-bottom: 1rem;
        }
        .header-banner img {
          border-radius: inherit;
        }
        h1 {
          font-size: 1.8rem;
        }
        h2 {
          font-size: 1.3rem;
        }
      }

      /* ── Prose ────────────────────────────────── */
      .prose { line-height: 1.7; }
      .prose p { margin: 0 0 1rem; }

      .prose h2 {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--accent);
        margin: 2.5rem 0 0.9rem;
        padding-bottom: 0.4rem;
        border-bottom: 1px solid var(--line);
      }
      .prose h3 {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--text);
        margin: 1.75rem 0 0.5rem;
      }
      .prose h4 {
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        color: var(--muted);
        margin: 1.25rem 0 0.4rem;
      }

      .prose table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        font-size: 0.9rem;
        margin: 1.25rem 0;
        border: 1px solid var(--line);
        border-radius: 10px;
        overflow: hidden;
      }
      .prose thead {
        background: linear-gradient(90deg, rgb(0 229 255 / 8%) 0%, transparent 100%);
      }
      .prose th {
        padding: 0.7rem 1rem;
        text-align: left;
        font-weight: 600;
        color: var(--accent);
        border-bottom: 2px solid var(--line);
        white-space: nowrap;
      }
      .prose td {
        padding: 0.6rem 1rem;
        border-bottom: 1px solid var(--line);
        vertical-align: top;
      }
      .prose tr:last-child td { border-bottom: 0; }
      .prose tbody tr:hover { background: rgb(0 229 255 / 4%); }

      .prose blockquote {
        margin: 1.25rem 0;
        padding: 1rem 1.25rem;
        border-left: 3px solid var(--accent);
        background: rgb(0 229 255 / 6%);
        border-radius: 0 8px 8px 0;
      }
      .prose blockquote p { margin: 0; line-height: 1.9; }

      .prose ul, .prose ol { margin: 0 0 1rem 1.35rem; padding: 0; }
      .prose li { margin-bottom: 0.35rem; }
      .prose li::marker { color: var(--accent); }

      .prose a { color: #00e5ff; text-decoration: none; }
      .prose a:hover { text-decoration: underline; }

      .prose strong { color: var(--text); font-weight: 600; }
      .prose em { color: var(--muted); font-style: italic; }

      .prose code {
        background: #111a30;
        border: 1px solid #1f2b46;
        border-radius: 0.35rem;
        padding: 0.1rem 0.4rem;
        font-size: 0.875em;
        font-family: "JetBrains Mono", Consolas, monospace;
      }
      .prose pre {
        background: #0c1324;
        border: 1px solid #1f2b46;
        border-radius: 10px;
        padding: 1.25rem 1.5rem;
        overflow-x: auto;
        margin: 1.25rem 0;
        font-size: 0.875rem;
        line-height: 1.65;
        font-family: "JetBrains Mono", Consolas, monospace;
      }
      .prose pre code {
        background: none;
        border: none;
        padding: 0;
        border-radius: 0;
        font-size: inherit;
      }

      .prose hr {
        border: 0;
        border-top: 1px solid var(--line);
        margin: 2rem 0;
      }

      /* ── Overview cards ── */
      .prose .overview-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(148px, 1fr));
        gap: 0.75rem;
        margin: 1.25rem 0;
      }
      .prose .overview-card {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        padding: 0.85rem 1rem;
        background: var(--surface);
        border: 1px solid var(--line);
        border-top: 2px solid var(--accent);
        border-radius: 10px;
        transition: box-shadow 0.2s ease, border-color 0.2s ease;
      }
      .prose .overview-card:hover {
        box-shadow: 0 0 1rem rgb(0 229 255 / 10%);
        border-color: rgb(0 229 255 / 40%);
        border-top-color: var(--accent);
      }
      .prose .overview-label {
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--muted);
      }
      .prose .overview-value {
        font-size: 0.975rem;
        font-weight: 600;
        color: var(--text);
      }

      .prose img {
        max-width: 100%;
        border-radius: 10px;
        border: 1px solid var(--line);
        margin: 1rem 0;
        display: block;
      }

      /* ── Accordion (details/summary) ── */
      .prose details {
        border: 1px solid var(--line);
        border-left: 3px solid var(--accent);
        border-radius: 0 10px 10px 0;
        margin: 0.75rem 0;
        background: var(--surface);
        overflow: hidden;
        transition: box-shadow 0.2s ease;
      }
      .prose details[open] {
        box-shadow: 0 0 1rem rgb(0 229 255 / 10%);
      }
      .prose summary {
        cursor: pointer;
        list-style: none;
        padding: 1rem 1.25rem;
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--text);
        display: flex;
        align-items: center;
        gap: 0.65rem;
        user-select: none;
        transition: background 0.15s ease, color 0.15s ease;
      }
      .prose summary::-webkit-details-marker { display: none; }
      .prose summary::before {
        content: "›";
        color: var(--accent);
        font-size: 1.25rem;
        line-height: 1;
        flex-shrink: 0;
        transition: transform 0.2s ease;
        display: inline-block;
      }
      .prose details.is-open > summary::before { transform: rotate(90deg); }
      .prose summary:hover { background: rgb(0 229 255 / 4%); color: var(--accent); }
      .prose details > *:not(summary) {
        padding-left: 1.25rem;
        padding-right: 1.25rem;
      }
      .prose details > *:not(summary):last-child { padding-bottom: 1.25rem; }

      /* ── Atlas node grid ── */
      .prose table[data-node-table] th {
        text-align: center;
        width: 80px;
      }
      .prose td[data-node="on"] {
        text-align: center;
        font-size: 1.15rem;
        color: var(--accent);
        background: linear-gradient(135deg, rgb(0 229 255 / 18%) 0%, rgb(0 229 255 / 8%) 100%);
        box-shadow: inset 0 0 0 1px rgb(0 229 255 / 35%);
        text-shadow: 0 0 8px rgb(0 229 255 / 70%);
      }
      .prose td[data-node="off"] {
        text-align: center;
        font-size: 1.1rem;
        color: rgb(100 116 139 / 0.45);
        background: rgb(0 0 0 / 25%);
      }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <a href="/" class="header-logo">
          <img src="/logo.png" alt="Orboro.net" />
        </a>
        <nav>
          <a href="/" class={isActive("/") ? "active" : ""}><Icon name="home" size={15} />Home</a>
          {navTree.map(node => {
            if (node.children.length > 0) {
              return (
                <div class="nav-dropdown-wrapper">
                  <a href={node.url} class={isActive(node.url) ? "active" : ""}><Icon name={nodeIcon(node)} size={15} />{node.label}</a>
                  <div class="nav-dropdown" set:html={renderDropdownItems(node.children)} />
                </div>
              );
            }
            return <a href={node.url} class={isActive(node.url) ? "active" : ""}><Icon name={nodeIcon(node)} size={15} />{node.label}</a>;
          })}
        </nav>
      </header>
      {pathname === "/" && (
        <div class="header-banner">
          <img src="/header.png" alt="Orboro header artwork" />
        </div>
      )}
      <main>
        <slot />
      </main>
      <Footer />
    </div>
    <script is:inline>
      function styleNodeTables() {
        document.querySelectorAll('.prose table').forEach(function(table) {
          var isNodeTable = false;
          table.querySelectorAll('td').forEach(function(td) {
            var text = td.textContent.trim();
            if (text === '✓') { td.setAttribute('data-node', 'on'); isNodeTable = true; }
            else if (text === '✗') { td.setAttribute('data-node', 'off'); isNodeTable = true; }
          });
          if (isNodeTable) table.setAttribute('data-node-table', '');
        });
      }

      function initAccordions() {
        document.querySelectorAll('.prose details').forEach(function(details) {
          if (details.dataset.accordionInit) return;
          details.dataset.accordionInit = '1';
          var summary = details.querySelector('summary');
          if (!summary) return;

          var wrapper = document.createElement('div');
          wrapper.className = 'details-body';
          Array.from(details.children).forEach(function(child) {
            if (child !== summary) wrapper.appendChild(child);
          });
          details.appendChild(wrapper);
          wrapper.style.cssText = 'overflow:hidden;transition:max-height 0.22s ease,opacity 0.18s ease;';

          if (details.open) {
            wrapper.style.maxHeight = wrapper.scrollHeight + 'px';
            wrapper.style.opacity = '1';
            details.classList.add('is-open');
          } else {
            wrapper.style.maxHeight = '0';
            wrapper.style.opacity = '0';
          }

          summary.addEventListener('click', function(e) {
            e.preventDefault();
            if (!details.open) {
              details.open = true;
              details.classList.add('is-open');
              wrapper.offsetHeight;
              wrapper.style.maxHeight = wrapper.scrollHeight + 'px';
              wrapper.style.opacity = '1';
            } else {
              details.classList.remove('is-open');
              wrapper.style.maxHeight = '0';
              wrapper.style.opacity = '0';
              var done = false;
              wrapper.addEventListener('transitionend', function handler(ev) {
                if (done || ev.propertyName !== 'max-height') return;
                done = true;
                details.open = false;
                wrapper.removeEventListener('transitionend', handler);
              });
            }
          });
        });
      }

      styleNodeTables();
      initAccordions();
      document.addEventListener('astro:page-load', function() {
        styleNodeTables();
        initAccordions();
      });
    </script>
  </body>
</html>
