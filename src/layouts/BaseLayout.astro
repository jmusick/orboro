---
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style>
      :root {
        --bg: #05070f;
        --surface: #0c1324;
        --surface-2: #111a30;
        --text: #e8f3ff;
        --muted: #97a8c4;
        --accent: #00e5ff;
        --accent-2: #ff3fb8;
        --accent-3: #a8ff60;
        --line: #1f2b46;
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        font-family: "Space Grotesk", "Segoe UI", sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at 15% 10%, rgb(0 229 255 / 14%) 0%, transparent 32%),
          radial-gradient(circle at 85% 15%, rgb(255 63 184 / 12%) 0%, transparent 28%),
          radial-gradient(circle at 50% 95%, rgb(168 255 96 / 10%) 0%, transparent 38%),
          var(--bg);
        background-repeat: no-repeat;
        background-size: 140vw 140vh, 130vw 130vh, 150vw 150vh, auto;
        background-attachment: fixed;
      }
      a {
        color: var(--accent);
        text-underline-offset: 2px;
      }
      .container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 1.2rem;
      }
      header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
        padding: 1.5rem 0;
        margin-bottom: 0.85rem;
      }
      .header-logo {
        display: block;
        flex-shrink: 0;
        text-decoration: none;
        line-height: 0;
      }
      .header-logo img {
        width: 240px;
        height: auto;
      }
      nav {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
      }
      nav a {
        border: 1px solid transparent;
        border-radius: 8px;
        padding: 0.5rem 1rem;
        text-decoration: none;
        transition: all 0.2s ease;
        font-weight: 500;
        font-size: 0.95rem;
      }
      nav a:hover {
        border-color: var(--accent);
        background: linear-gradient(90deg, rgb(0 229 255 / 10%) 0%, transparent 100%);
        box-shadow: 0 0 0.8rem rgb(0 229 255 / 20%);
      }
      .header-banner {
        margin-bottom: 1.2rem;
        border-radius: 16px;
        overflow: hidden;
        line-height: 0;
      }
      .header-banner img {
        display: block;
        width: 100%;
        height: auto;
        max-height: none;
        object-fit: contain;
        border-radius: inherit;
      }
      main {
        background: linear-gradient(160deg, rgb(12 19 36 / 94%) 0%, rgb(17 26 48 / 94%) 100%);
        border: 1px solid var(--line);
        border-radius: 16px;
        box-shadow:
          0 0 1.2rem rgb(0 229 255 / 14%),
          0 1.5rem 3rem rgb(0 0 0 / 45%);
        padding: 2rem;
      }
      section + section {
        margin-top: 2.5rem;
      }
      section {
        animation: fadeIn 0.4s ease-out;
      }
      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      footer {
        /* styles moved to Footer.astro */
      }
      ul {
        padding-left: 1.2rem;
      }
      ul li {
        margin-bottom: 0.5rem;
      }
      input,
      textarea,
      select,
      button {
        font: inherit;
      }
      .mono {
        font-family: "JetBrains Mono", Consolas, monospace;
      }
      h1 {
        font-size: 2.2rem;
        margin: 0 0 1rem;
        font-weight: 700;
      }
      h2 {
        font-size: 1.6rem;
        margin: 0 0 1rem;
        font-weight: 600;
      }
      h3 {
        font-size: 1.2rem;
        margin: 0 0 0.75rem;
        font-weight: 600;
      }
      h1, h2, h3 {
        color: #f4f8ff;
      }
      p {
        line-height: 1.6;
        margin: 0 0 1rem;
      }
      hr {
        border: 0;
        border-top: 1px solid var(--line);
        margin: 2rem 0;
      }
      @media (max-width: 768px) {
        main {
          padding: 1.5rem;
        }
        header {
          flex-direction: column;
          gap: 1rem;
          align-items: flex-start;
        }
        nav {
          width: 100%;
          justify-content: flex-start;
        }
        .header-banner {
          margin-bottom: 1rem;
        }
        .header-banner img {
          border-radius: inherit;
        }
        h1 {
          font-size: 1.8rem;
        }
        h2 {
          font-size: 1.3rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <a href="/" class="header-logo">
          <img src="/logo.png" alt="Orboro.net" />
        </a>
        <nav>
          <a href="/">Home</a>
          <a href="/admin">Admin</a>
        </nav>
      </header>
      <div class="header-banner">
        <img src="/header.png" alt="Orboro header artwork" />
      </div>
      <main>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
