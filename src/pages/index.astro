---
import { marked } from "marked";
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";
import { getPublishedContentByType, excerptFromMarkdown } from "../lib/content";

const rawPosts = await getPublishedContentByType(Astro.locals, "post", 8);
const posts = await Promise.all(rawPosts.map(async (post) => {
	const date = post.publishedAt ?? post.createdAt;
	const excerpt = excerptFromMarkdown(post.markdown, 600);
	const truncated = excerpt.endsWith("…");
	return {
		...post,
		excerpt,
		truncated,
		fullHtml: truncated ? ((await marked.parse(post.markdown)) as string) : "",
		dateLabel: new Date(date).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" }),
	};
}));

const profiles = [
	{
		platform: "Discord",
		handle: "xing_yuen",
		icon: "discord",
	},
	{
		platform: "Battle.net",
		handle: "Xing#1673",
		icon: "battlenet",
	},
	{
		platform: "Steam",
		handle: "XingYuen",
		icon: "steam",
		url: "https://steamcommunity.com/id/XingYuen/",
	},
	{
		platform: "Reddit",
		handle: "u/XingYuen",
		icon: "reddit",
		url: "https://www.reddit.com/user/XingYuen/",
	},
	{
		platform: "YouTube",
		handle: "@XingYuen",
		icon: "youtube",
		url: "https://www.youtube.com/@XingYuen",
	},
	{
		platform: "Twitch",
		handle: "xingyuen",
		icon: "twitch",
		url: "https://www.twitch.tv/xingyuen",
	},
];
---


<BaseLayout title="Orboro.net" description="Latest posts and gamer profiles from Orboro.net.">
	<div class="home-layout">
		<section class="feed-section">
			<div class="feed-header">
				<h2>Latest Posts</h2>
				<Button href="/blog" variant="tertiary" icon="chevron-right" iconPosition="right">View all posts</Button>
			</div>
			{posts.length === 0 ? (
				<p class="empty-note">No posts published yet.</p>
			) : (
				<div class="feed-list" id="home-feed">
					{posts.map((post) => (
						<article class="feed-item">
							<p class="feed-item__date">{post.dateLabel}</p>
							<h3 class="feed-item__title"><a href={`/blog/${post.slug}`}>{post.title}</a></h3>
							{post.excerpt && <p class="feed-item__excerpt">{post.excerpt}</p>}
							{post.truncated && <div class="feed-item__full prose" hidden set:html={post.fullHtml} />}
							{post.truncated && (
								<button type="button" class="feed-item__toggle">Show full post</button>
							)}
						</article>
					))}
				</div>
			)}
		</section>

		<aside class="profiles-column">
			<h2>Find Me Elsewhere</h2>
			<div class="profiles-list">
				{profiles.map((profile) => {
					const Tag = profile.url ? "a" : "div";
					const linkProps = profile.url ? { href: profile.url, target: "_blank", rel: "noopener noreferrer" } : {};
					return (
						<Tag class="profile-row" {...linkProps}>
							<Icon name={profile.icon} size={20} filled={true} />
							<span class="profile-row__text">
								<strong>{profile.platform}</strong>
								<span>{profile.handle}</span>
							</span>
							{profile.url && <Icon name="external-link" size={14} class="profile-row__external" />}
						</Tag>
					);
				})}
			</div>
		</aside>
	</div>
</BaseLayout>

<script is:inline>
	(function () {
		function init() {
			var root = document.getElementById('home-feed');
			if (!root || root.dataset.feedInit) return;
			root.dataset.feedInit = '1';

			root.querySelectorAll('.feed-item__toggle').forEach(function (btn) {
				btn.addEventListener('click', function () {
					var item = btn.closest('.feed-item');
					if (!item) return;
					var excerpt = item.querySelector('.feed-item__excerpt');
					var full = item.querySelector('.feed-item__full');
					var expanded = full ? full.hidden : false;
					if (excerpt) excerpt.hidden = expanded;
					if (full) full.hidden = !expanded;
					btn.textContent = expanded ? 'Show less' : 'Show full post';
				});
			});
		}
		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', init);
		} else {
			init();
		}
		document.addEventListener('astro:page-load', init);
	})();
</script>

<style>
	.home-layout {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 2.5rem;
		align-items: start;
	}

	.feed-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		margin-bottom: 1.25rem;
	}

	.feed-header h2,
	.profiles-column h2 {
		margin: 0;
		font-size: 1.3rem;
	}

	.profiles-column h2 {
		margin-bottom: 1.25rem;
	}

	.empty-note {
		color: var(--muted);
	}

	.feed-list {
		display: flex;
		flex-direction: column;
	}

	.feed-item {
		padding: 1.1rem 0;
		border-bottom: 1px solid var(--line);
	}

	.feed-item:first-child {
		padding-top: 0;
	}

	.feed-item:last-child {
		border-bottom: none;
	}

	.feed-item__date {
		margin: 0 0 0.3rem;
		font-size: 0.8rem;
		color: var(--muted);
	}

	.feed-item__title {
		margin: 0 0 0.4rem;
		font-size: 1.1rem;
		font-weight: 600;
	}

	.feed-item__title a {
		color: var(--text);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.feed-item__title a:hover {
		color: var(--accent);
	}

	.feed-item__excerpt {
		margin: 0;
		font-size: 0.92rem;
		color: var(--muted);
		line-height: 1.5;
	}

	.feed-item__full {
		margin-top: 0.75rem;
	}

	.feed-item__toggle {
		margin-top: 0.75rem;
		padding: 0.4rem 0.9rem;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: var(--surface);
		color: var(--accent);
		font-family: inherit;
		font-size: 0.85rem;
		font-weight: 500;
		cursor: pointer;
		transition: all 0.2s ease;
	}

	.feed-item__toggle:hover {
		border-color: var(--accent);
		background: rgb(0 229 255 / 8%);
	}

	.profiles-list {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.profile-row {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.6rem 0.75rem;
		background: linear-gradient(160deg, rgb(12 19 36 / 60%) 0%, rgb(17 26 48 / 60%) 100%);
		border: 1px solid var(--line);
		border-radius: 10px;
		color: inherit;
		text-decoration: none;
		transition: all 0.2s ease;
	}

	a.profile-row:hover {
		border-color: var(--accent);
		box-shadow: 0 0 0.8rem rgb(0 229 255 / 15%);
	}

	.profile-row :global(svg) {
		flex-shrink: 0;
		color: var(--accent);
	}

	.profile-row :global(.profile-row__external) {
		margin-left: auto;
		color: var(--muted);
		transition: color 0.2s ease;
	}

	a.profile-row:hover :global(.profile-row__external) {
		color: var(--accent);
	}

	.profile-row__text {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
		min-width: 0;
		font-size: 0.85rem;
	}

	.profile-row__text strong {
		font-size: 0.9rem;
		color: var(--text);
	}

	.profile-row__text span {
		color: var(--muted);
		font-family: "JetBrains Mono", Consolas, monospace;
		font-size: 0.8rem;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	@media (max-width: 900px) {
		.home-layout {
			grid-template-columns: 1fr;
		}

		.profiles-column {
			order: -1;
		}

		.profiles-list {
			flex-direction: row;
			flex-wrap: wrap;
		}

		.profile-row {
			flex: 1 1 calc(50% - 0.3rem);
			min-width: 200px;
		}
	}

	@media (max-width: 480px) {
		.profile-row {
			flex: 1 1 100%;
		}
	}
</style>
