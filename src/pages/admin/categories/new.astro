---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import Button from "../../../components/Button.astro";
import { ensureRole } from "../../../lib/http";

ensureRole(Astro, ["admin", "editor"]);
---

<AdminLayout title="New Category">
  <section class="editor-section">
    <form method="post" action="/api/categories/save" class="category-editor">
      <div class="form-row">
        <div class="form-group">
          <label for="name">Name</label>
          <input id="name" type="text" name="name" required placeholder="Category name" />
        </div>
        <div class="form-group">
          <label for="slug">Slug</label>
          <input id="slug" type="text" name="slug" required placeholder="category-slug" />
        </div>
      </div>

      <div class="form-actions">
        <Button href="/admin/categories" variant="secondary">
          Cancel
        </Button>
        <Button type="submit" variant="primary" icon="check">
          Create Category
        </Button>
      </div>
    </form>
  </section>

  <script is:inline>
    (function () {
      var nameEl = document.querySelector('#name');
      var slugEl = document.querySelector('#slug');
      if (!(nameEl instanceof HTMLInputElement) || !(slugEl instanceof HTMLInputElement)) return;
      var slugDirty = false;
      slugEl.addEventListener('input', function () { slugDirty = true; });
      nameEl.addEventListener('input', function () {
        if (slugDirty) return;
        slugEl.value = nameEl.value
          .toLowerCase()
          .trim()
          .replace(/[^a-z0-9\s-]/g, '')
          .replace(/[\s-]+/g, '-')
          .replace(/^-+|-+$/g, '');
      });
    })();
  </script>

  <style>
    .editor-section {
      margin-bottom: 2rem;
    }

    .category-editor {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .form-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1rem;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .form-group label {
      font-weight: 600;
      font-size: 0.95rem;
      color: var(--text);
    }

    .form-group input {
      padding: 0.75rem 1rem;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--surface);
      color: var(--text);
      font-family: inherit;
      font-size: 0.95rem;
      transition: all 0.2s ease;
    }

    .form-group input::placeholder {
      color: var(--muted);
    }

    .form-group input:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0.8rem rgb(0 229 255 / 20%);
    }

    .form-actions {
      display: flex;
      gap: 1rem;
      align-items: center;
      justify-content: flex-end;
      padding: 1.5rem 0;
      border-top: 1px solid var(--line);
    }

    @media (max-width: 768px) {
      .form-row {
        grid-template-columns: 1fr;
      }

      .form-actions {
        flex-direction: column;
        align-items: stretch;
      }
    }
  </style>
</AdminLayout>
