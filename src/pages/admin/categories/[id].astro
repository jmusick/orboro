---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import Button from "../../../components/Button.astro";
import { getCategoryById } from "../../../lib/content";
import { ensureRole } from "../../../lib/http";

ensureRole(Astro, ["admin", "editor"]);

const { id } = Astro.params;
if (!id) {
  return Astro.redirect("/admin/categories");
}

const category = await getCategoryById(Astro.locals, id);
if (!category) {
  return Astro.redirect("/admin/categories");
}

const url = new URL(Astro.request.url);
const saved = url.searchParams.get("saved") === "1";
---

<AdminLayout title={`Edit ${category.name}`}>
  {saved && (
    <div class="success-banner">Category saved successfully.</div>
  )}

  <section class="editor-section">
    <form method="post" action="/api/categories/save" class="category-editor">
      <input type="hidden" name="id" value={category.id} />

      <div class="form-row">
        <div class="form-group">
          <label for="name">Name</label>
          <input id="name" type="text" name="name" value={category.name} required placeholder="Category name" />
        </div>
        <div class="form-group">
          <label for="slug">Slug</label>
          <input id="slug" type="text" name="slug" value={category.slug} required placeholder="category-slug" />
        </div>
      </div>

      <div class="form-actions">
        <Button href="/admin/categories" variant="secondary">
          Cancel
        </Button>
        <Button type="submit" variant="primary" icon="check">
          Save Changes
        </Button>
      </div>
    </form>

    <section class="delete-section">
      <h3>Danger Zone</h3>
      <p>Delete this category permanently. This action cannot be undone.</p>
      <form method="post" action="/api/categories/delete" class="delete-form" onsubmit="return confirm('Delete this category? This cannot be undone.');">
        <input type="hidden" name="id" value={category.id} />
        <Button type="submit" variant="danger" icon="trash-2">
          Delete Category
        </Button>
      </form>
    </section>
  </section>

  <script is:inline>
    (function () {
      var nameEl = document.querySelector('#name');
      var slugEl = document.querySelector('#slug');
      if (!(nameEl instanceof HTMLInputElement) || !(slugEl instanceof HTMLInputElement)) return;
      var slugDirty = false;
      slugEl.addEventListener('input', function () { slugDirty = true; });
      nameEl.addEventListener('input', function () {
        if (slugDirty) return;
        slugEl.value = nameEl.value
          .toLowerCase()
          .trim()
          .replace(/[^a-z0-9\s-]/g, '')
          .replace(/[\s-]+/g, '-')
          .replace(/^-+|-+$/g, '');
      });
    })();
  </script>

  <style>
    .editor-section {
      margin-bottom: 2rem;
    }

    .category-editor {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .form-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1rem;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .form-group label {
      font-weight: 600;
      font-size: 0.95rem;
      color: var(--text);
    }

    .form-group input {
      padding: 0.75rem 1rem;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--surface);
      color: var(--text);
      font-family: inherit;
      font-size: 0.95rem;
      transition: all 0.2s ease;
    }

    .form-group input::placeholder {
      color: var(--muted);
    }

    .form-group input:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0.8rem rgb(0 229 255 / 20%);
    }

    .form-actions {
      display: flex;
      gap: 1rem;
      align-items: center;
      justify-content: flex-end;
      padding: 1.5rem 0;
      border-top: 1px solid var(--line);
    }

    .delete-section {
      padding: 1.5rem;
      border: 2px solid rgb(255 61 77 / 30%);
      border-radius: 12px;
      background: linear-gradient(160deg, rgb(255 61 77 / 5%) 0%, transparent 100%);
      margin-top: 2rem;
    }

    .delete-section h3 {
      margin: 0 0 0.5rem;
      color: #ff3d4d;
      font-size: 1.1rem;
    }

    .delete-section p {
      margin: 0 0 1rem;
      color: var(--muted);
      font-size: 0.9rem;
    }

    .delete-form {
      display: inline-block;
    }

    @media (max-width: 768px) {
      .form-row {
        grid-template-columns: 1fr;
      }

      .form-actions {
        flex-direction: column;
        align-items: stretch;
      }

      .delete-form :global(.btn) {
        width: 100%;
      }
    }
  </style>
</AdminLayout>

<style>
  .success-banner {
    padding: 0.75rem 1rem;
    background: rgb(168 255 96 / 15%);
    border: 1px solid rgb(168 255 96 / 40%);
    border-radius: 8px;
    color: var(--accent-3);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }
</style>
