---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import Button from "../../../components/Button.astro";
import Icon from "../../../components/Icon.astro";
import { ensureRole } from "../../../lib/http";
import { listMedia } from "../../../lib/content";

ensureRole(Astro, ["admin", "editor"]);
const media = await listMedia(Astro.locals);
---

<AdminLayout title="Media">
  <section class="form-section">
    <h2>Add Media</h2>
    <form action="/api/media/save" method="post" class="media-form">
      <div class="form-group">
        <label for="url">Image URL</label>
        <input id="url" name="url" type="url" required placeholder="https://example.com/image.jpg" />
      </div>
      <div class="form-group">
        <label for="altText">Alt text</label>
        <input id="altText" name="altText" type="text" required placeholder="Description of the image" />
      </div>
      <div class="form-group">
        <label for="caption">Caption</label>
        <textarea id="caption" name="caption" rows="2" placeholder="Optional caption for the media"></textarea>
      </div>
      <Button type="submit" variant="primary" icon="upload">
        Add Media Record
      </Button>
    </form>
  </section>

  <section class="library-section">
    <h2>Media Library</h2>
    {media.length === 0 ? (
      <div class="empty-library">
        <Icon name="image" size={48} />
        <p>No media records yet.</p>
        <p class="muted-text">Upload your first media record using the form above</p>
      </div>
    ) : (
      <div class="media-grid">
        {media.map((item) => (
          <div class="media-card">
            <div class="media-header">
              <strong title={item.altText} class="media-title">{item.altText}</strong>
            </div>
            <div class="media-content">
              {item.caption && (
                <p class="media-caption">{item.caption}</p>
              )}
              <a href={item.url} target="_blank" rel="noreferrer" class="media-url">
                View Image
              </a>
            </div>
            <div class="media-footer">
              <form method="post" action="/api/media/delete" class="delete-form" onsubmit="return confirm('Delete this media record?');">
                <input type="hidden" name="id" value={item.id} />
                <Button type="submit" variant="danger" size="sm" icon="trash-2">
                  Delete
                </Button>
              </form>
            </div>
          </div>
        ))}
      </div>
    )}
  </section>
</AdminLayout>

<style>
  .form-section {
    margin-bottom: 3rem;
  }

  .media-form {
    background: linear-gradient(160deg, rgb(12 19 36 / 50%) 0%, rgb(17 26 48 / 50%) 100%);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .form-group label {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text);
  }

  .form-group input,
  .form-group textarea {
    padding: 0.75rem 1rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    color: var(--text);
    font-family: inherit;
    font-size: 1rem;
    transition: all 0.2s ease;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--muted);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0.8rem rgb(0 229 255 / 20%);
  }

  .library-section {
    margin-top: 2rem;
  }

  .empty-library {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 3rem 1rem;
    text-align: center;
    color: var(--muted);
  }

  .empty-library svg {
    opacity: 0.5;
  }

  .empty-library p {
    margin: 0;
  }

  .muted-text {
    font-size: 0.9rem;
    color: var(--muted);
  }

  .media-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .media-card {
    display: flex;
    flex-direction: column;
    background: linear-gradient(160deg, rgb(12 19 36 / 60%) 0%, rgb(17 26 48 / 60%) 100%);
    border: 1px solid var(--line);
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.2s ease;
  }

  .media-card:hover {
    border-color: var(--accent);
    box-shadow: 0 0 1.2rem rgb(0 229 255 / 15%);
  }

  .media-header {
    padding: 1rem;
    border-bottom: 1px solid var(--line);
    background: linear-gradient(90deg, rgb(0 229 255 / 5%) 0%, transparent 100%);
  }

  .media-title {
    display: block;
    color: var(--text);
    word-break: break-word;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .media-content {
    flex: 1;
    padding: 1rem;
  }

  .media-caption {
    font-size: 0.9rem;
    color: var(--muted);
    margin: 0 0 0.75rem;
    line-height: 1.4;
  }

  .media-url {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--accent);
    text-decoration: none;
    font-size: 0.9rem;
    transition: all 0.2s ease;
  }

  .media-url:hover {
    text-decoration: underline;
  }

  .media-footer {
    padding: 1rem;
    border-top: 1px solid var(--line);
    background: linear-gradient(90deg, transparent 0%, rgb(255 61 77 / 3%) 100%);
  }

  .delete-form {
    display: block;
    width: 100%;
  }

  .delete-form :global(.btn) {
    width: 100%;
  }

  @media (max-width: 768px) {
    .media-grid {
      grid-template-columns: 1fr;
    }

    .media-form {
      padding: 1rem;
    }
  }
</style>
