---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import Button from "../../../components/Button.astro";
import { ensureRole } from "../../../lib/http";
import { getTemplateOptionsByType } from "../../../lib/templates";

ensureRole(Astro, ["admin", "editor", "author"]);

const templateOptionsByType = getTemplateOptionsByType();
const allTemplateOptions = [...templateOptionsByType.post, ...templateOptionsByType.page];
---

<AdminLayout title="Create Content">
  <section class="editor-section">
    <form method="post" action="/api/content/save" id="content-form" class="content-editor">
      <div class="form-row">
        <div class="form-group">
          <label for="title">Title</label>
          <input id="title" type="text" name="title" required placeholder="Enter content title" />
        </div>
        <div class="form-group">
          <label for="slug">Slug</label>
          <input id="slug" type="text" name="slug" required placeholder="my-post" />
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="pageType">Page Type</label>
          <select id="pageType" name="pageType">
            <option value="post">post (blog)</option>
            <option value="page">page (generic)</option>
          </select>
        </div>
        <div class="form-group">
          <label for="status">Status</label>
          <select id="status" name="status">
            <option value="draft">draft</option>
            <option value="published">published</option>
          </select>
        </div>
        <div class="form-group">
          <label for="templateKey">Template</label>
          <select id="templateKey" name="templateKey">
            {allTemplateOptions.map((option) => (
              <option value={option.key}>{option.label}</option>
            ))}
          </select>
        </div>
      </div>

      <div class="form-group full">
        <label for="excerpt">Excerpt</label>
        <textarea id="excerpt" name="excerpt" rows="2" placeholder="Brief summary of the content"></textarea>
      </div>

      <div class="form-group full">
        <label for="templateDataJson">Template Data (JSON, optional)</label>
        <textarea
          id="templateDataJson"
          name="templateDataJson"
          rows="3"
          placeholder='{"key": "value"}'
        ></textarea>
      </div>

      <div class="form-group full">
        <label for="markdown">Markdown Content</label>
        <textarea id="markdown" name="markdown" rows="20" required placeholder="Write your content in Markdown..."></textarea>
      </div>

      <div class="form-actions">
        <div class="preview-toggle">
          <Button type="button" id="preview-toggle" variant="secondary" icon="eye">
            Show Preview
          </Button>
        </div>
        <div class="submit-buttons">
          <Button type="submit" variant="primary" icon="check">
            Publish Content
          </Button>
        </div>
      </div>

      <div id="preview" class="preview-pane" style="display:none;"></div>
    </form>
  </section>

  <script type="module" src="/admin-editor.js"></script>

  <style>
    .editor-section {
      margin-bottom: 2rem;
    }

    .content-editor {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .form-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1rem;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .form-group.full {
      grid-column: 1 / -1;
    }

    .form-group label {
      font-weight: 600;
      font-size: 0.95rem;
      color: var(--text);
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
      padding: 0.75rem 1rem;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--surface);
      color: var(--text);
      font-family: inherit;
      font-size: 0.95rem;
      transition: all 0.2s ease;
      resize: vertical;
    }

    .form-group input::placeholder,
    .form-group textarea::placeholder {
      color: var(--muted);
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0.8rem rgb(0 229 255 / 20%);
    }

    .form-group select {
      cursor: pointer;
    }

    .form-actions {
      display: flex;
      gap: 1rem;
      align-items: center;
      justify-content: space-between;
      padding: 1.5rem 0;
      border-top: 1px solid var(--line);
      flex-wrap: wrap;
    }

    .submit-buttons {
      display: flex;
      gap: 0.5rem;
    }

    .preview-pane {
      background: linear-gradient(160deg, rgb(12 19 36 / 60%) 0%, rgb(17 26 48 / 60%) 100%);
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 2rem;
      margin-top: 1rem;
    }

    @media (max-width: 768px) {
      .form-row {
        grid-template-columns: 1fr;
      }

      .form-actions {
        flex-direction: column;
        align-items: stretch;
      }

      .preview-toggle,
      .submit-buttons {
        width: 100%;
      }

      .preview-toggle :global(.btn),
      .submit-buttons :global(.btn) {
        width: 100%;
      }
    }
  </style>
</AdminLayout>
