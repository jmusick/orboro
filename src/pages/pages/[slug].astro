---
import { marked } from "marked";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedBySlugAndType } from "../../lib/content";
import { processShortcodes } from "../../lib/shortcodes";

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/");

const page = await getPublishedBySlugAndType(Astro.locals, slug, "page");
if (!page) return Astro.redirect("/");

const html = processShortcodes(String(await marked.parse(page.markdown)));
const updated = new Date(page.updatedAt).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

function descriptionFromMarkdown(md: string, maxLen = 155): string {
  const plain = md
    .replace(/```[\s\S]*?```/g, '')
    .replace(/#{1,6}\s+[^\n]*/g, '')
    .replace(/!\[.*?\]\(.*?\)/g, '')
    .replace(/\[(.+?)\]\(.*?\)/g, '$1')
    .replace(/[*_`~]+/g, '')
    .replace(/^\s*[-*+>|]\s*/gm, '')
    .replace(/\n+/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
  return plain.length > maxLen ? plain.slice(0, maxLen).trimEnd() + '…' : plain;
}

const description = descriptionFromMarkdown(page.markdown);
---

<BaseLayout title={`${page.title} | Orboro.net`} description={description} ogType="article">
  <article class="page-content">
    <h1>{page.title}</h1>
    <p class="meta">Updated {updated}</p>
    <div class="prose" set:html={html} />
  </article>
</BaseLayout>

<style>
  .meta {
    color: var(--muted);
    font-size: 0.9rem;
    margin: -0.5rem 0 1.5rem;
  }
</style>
