---
import { marked } from "marked";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedBySlugAndType } from "../../lib/content";

const { slug } = Astro.params;
if (!slug) {
  return Astro.redirect("/blog");
}

const post = await getPublishedBySlugAndType(Astro.locals, slug, "post");
if (!post) {
  return Astro.redirect("/blog");
}

const html = (await marked.parse(post.markdown)) as string;

const updated = new Date(post.updatedAt).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

function descriptionFromMarkdown(md: string, maxLen = 155): string {
  const plain = md
    .replace(/```[\s\S]*?```/g, '')
    .replace(/#{1,6}\s+[^\n]*/g, '')
    .replace(/!\[.*?\]\(.*?\)/g, '')
    .replace(/\[(.+?)\]\(.*?\)/g, '$1')
    .replace(/[*_`~]+/g, '')
    .replace(/^\s*[-*+>|]\s*/gm, '')
    .replace(/\n+/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
  return plain.length > maxLen ? plain.slice(0, maxLen).trimEnd() + '…' : plain;
}

const description = descriptionFromMarkdown(post.markdown);
---

<BaseLayout title={`${post.title} | Orboro.net`} description={description} ogType="article">
  <article>
    <h1>{post.title}</h1>
    <p class="meta">Updated {updated}</p>
    <hr />
    <div class="prose" set:html={html} />
  </article>
</BaseLayout>

<style>
  .meta {
    color: var(--muted);
    font-size: 0.9rem;
    margin: -0.5rem 0 1.5rem;
  }
</style>
