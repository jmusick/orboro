---
import { marked } from "marked";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedBySlugAndType } from "../../lib/content";

const { slug } = Astro.params;
if (!slug) {
  return Astro.redirect("/blog");
}

const post = await getPublishedBySlugAndType(Astro.locals, slug, "post");
if (!post) {
  return Astro.redirect("/blog");
}

const html = (await marked.parse(post.markdown)) as string;

const updated = new Date(post.updatedAt).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---

<BaseLayout title={`${post.title} | Orboro.net`}>
  <article>
    <h1>{post.title}</h1>
    <p class="meta">Updated {updated}</p>
    <hr />
    <div class="prose" set:html={html} />
  </article>
</BaseLayout>

<style>
  .meta {
    color: var(--muted);
    font-size: 0.9rem;
    margin: -0.5rem 0 1.5rem;
  }
</style>
