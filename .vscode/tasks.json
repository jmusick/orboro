{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "orboro: dev",
      "type": "shell",
      "command": "npm run dev:astro",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      },
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "ready in"
        }
      }
    }
  ]
}
